{
  "login": {
    "method": "cookies",
    "headless": false,
    "profile_dir": "./chrome_profile"
  },
  "crawl": {
    "pages_file": "pages.txt",
    "max_workers": 3,
    "login_stagger_seconds": 2,
    "wait_after_load": 3,
    "wait_between_pages": 2,
    "element_timeout": 15,
    "output_file": "crawl_results.json",
    "user_agent_rotation": true,
    "proxy_rotation": false,
    "scroll_until_stable": {
      "max_scrolls": 80,
      "stable_rounds": 4,
      "scroll_pause_seconds": 2.0,
      "settle_pause_seconds": 0.5
    }
  },
  "selectors": {
    "modules_dir": "configs/modules"
  }
}
