# Facebook cookie string (required when LOGIN_METHOD=cookies)
COOKIES=

# Browser fingerprint (recommended)
USER_AGENT=

# Login mode: cookies | profile
LOGIN_METHOD=profile

# Single Chrome profile directory
PROFILE_DIR=./chrome_profile

# Multiple profile directories for crawler workers (comma-separated)
PROFILE_DIRS=./chrome_profile_1,./chrome_profile_2,./chrome_profile_3

# Run crawler in headless mode: true | false
HEADLESS=false

# Primary proxy (optional), e.g. http://user:pass@host:port
PROXY=

# Fallback proxy list file
PROXIES_FILE=proxies.txt

# Max crawler workers (auto-limited by login mode and profiles)
MAX_WORKERS=3
