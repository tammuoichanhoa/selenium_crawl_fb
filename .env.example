# Facebook cookie string (required when LOGIN_METHOD=cookies)
COOKIES=
HEADLESS=false
# Browser fingerprint (recommended)
# USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Safari/537.36
USER_AGENTS_FILE=user_agents.txt

# Login mode: cookies | profile
LOGIN_METHOD=cookies

# # Single Chrome profile directory
# PROFILE_DIR=./chrome_profile

DEBUG_PORT_START=8000
PORT_RANGE_MIN=8000
PORT_RANGE_MAX=9999
PORT_POOL_SIZE=100
# MAX_WORKERS=3
LOCATOR_GUARD=error

# Selector debug & capture
SELECTOR_DEBUG=1
SELECTOR_LOG_CONFIG=1
SELECTOR_CAPTURE=1
SELECTOR_CAPTURE_DIR=./debug_artifacts


SELECTOR_SITE=facebook
SELECTOR_ENV=prod
SELECTOR_MODULE=page
SELECTOR_PAGE=about
SELECTOR_ENDPOINT=https://gasoline-asn-protecting-pictures.trycloudflare.com/configs/auto-node
SELECTOR_CACHE_DIR=./selector_cache
SELECTOR_AUTO_DOWNLOAD=1
