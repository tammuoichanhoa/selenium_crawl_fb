{
  "login": {
    "method": "cookies",
    "headless": false,
    "profile_dir": "./chrome_profile"
  },
  "crawl": {
    "pages_file": "pages.txt",
    "max_workers": 3,
    "login_stagger_seconds": 2,
    "wait_after_load": 3,
    "wait_between_pages": 2,
    "element_timeout": 15,
    "output_file": "crawl_results.json"
  },
  "selectors": {
    "modules": {
      "page": {
        "site": "facebook",
        "module": "page",
        "page": "about",
        "environment": "dev",
        "version": "1.0.0",
        "updated_at": "2026-03-07T00:00:00Z",
        "updated_by": "crawler-team",
        "defaults": {
          "wait": {
            "state": "presence",
            "timeout_ms": 15000
          }
        },
        "elements": {
          "page.page_title": {
            "primary": {
              "type": "css",
              "value": "h1",
              "priority": 6
            },
            "fallbacks": [
              {
                "type": "xpath",
                "value": "//h1",
                "priority": 5
              }
            ],
            "wait": {
              "state": "visible",
              "timeout_ms": 15000
            },
            "attribute": "text"
          }
        }
      },
      "profile": {
